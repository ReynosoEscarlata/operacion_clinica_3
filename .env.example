# --- Server ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- PostgreSQL / Prisma ---
DATABASE_URL=postgresql://clinic:clinic@localhost:5432/clinic_scheduler?schema=public

# --- Redis / BullMQ ---
REDIS_URL=redis://localhost:6379

# --- Stripe (modo test) ---
STRIPE_SECRET_KEY=replace-with-your-stripe-test-secret-key
STRIPE_WEBHOOK_SECRET=replace-with-your-stripe-webhook-secret

# --- Resend (email) ---
RESEND_API_KEY=replace-with-your-resend-api-key
RESEND_FROM_EMAIL=no-reply@clinica.example.com

# --- Sentry ---
SENTRY_DSN=

# --- Admin auth ---
ADMIN_API_KEY=changeme
