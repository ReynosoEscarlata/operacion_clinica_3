{
  "consumer": {
    "name": "appointments"
  },
  "interactions": [
    {
      "description": "una cancelación de payment intent",
      "providerStates": [
        {
          "name": "el payment intent existe y se puede cancelar"
        }
      ],
      "request": {
        "method": "POST",
        "path": "/v1/payment-intents/pi_123/cancel"
      },
      "response": {
        "status": 200
      }
    },
    {
      "description": "una creación de customer",
      "providerStates": [
        {
          "name": "Stripe acepta crear customers"
        }
      ],
      "request": {
        "body": {
          "email": "paciente@example.com",
          "name": "Paciente Test"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "method": "POST",
        "path": "/v1/customers"
      },
      "response": {
        "body": {
          "id": "cus_123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "una creación de payment intent",
      "providerStates": [
        {
          "name": "Stripe acepta crear payment intents"
        }
      ],
      "request": {
        "body": {
          "amountCents": 50000,
          "appointmentId": "44444444-4444-4444-4444-444444444444",
          "patientStripeCustomerId": "cus_123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.amountCents": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.appointmentId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.patientStripeCustomerId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/payment-intents"
      },
      "response": {
        "body": {
          "clientSecret": "secret_123",
          "id": "pi_123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.clientSecret": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    },
    {
      "description": "una creación de refund",
      "providerStates": [
        {
          "name": "el payment intent existe y se puede reembolsar"
        }
      ],
      "request": {
        "body": {
          "amountCents": 25000,
          "appointmentId": "44444444-4444-4444-4444-444444444444",
          "paymentIntentId": "pi_123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.amountCents": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            },
            "$.appointmentId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            },
            "$.paymentIntentId": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "method": "POST",
        "path": "/v1/refunds"
      },
      "response": {
        "body": {
          "id": "re_123"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 201
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "payments"
  }
}