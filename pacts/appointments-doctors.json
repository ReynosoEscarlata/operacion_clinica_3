{
  "consumer": {
    "name": "appointments"
  },
  "interactions": [
    {
      "description": "una consulta de datos básicos de un doctor",
      "providerStates": [
        {
          "name": "el doctor existe"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/doctors/11111111-1111-1111-1111-111111111111"
      },
      "response": {
        "body": {
          "consultationPriceCents": 50000,
          "id": "11111111-1111-1111-1111-111111111111"
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.consultationPriceCents": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
            "$.id": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "regex",
                  "regex": "[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "una consulta de horarios disponibles",
      "providerStates": [
        {
          "name": "el doctor tiene disponibilidad configurada"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/doctors/33333333-3333-3333-3333-333333333333/slots",
        "query": {
          "date": [
            "2026-07-01"
          ]
        }
      },
      "response": {
        "body": {
          "slots": [
            "2026-07-01T09:00:00.000Z",
            "2026-07-01T09:30:00.000Z"
          ]
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.slots": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "type"
                }
              ]
            }
          }
        },
        "status": 200
      }
    },
    {
      "description": "una consulta de un doctor inexistente",
      "providerStates": [
        {
          "name": "el doctor no existe"
        }
      ],
      "request": {
        "method": "GET",
        "path": "/v1/doctors/22222222-2222-2222-2222-222222222222"
      },
      "response": {
        "status": 404
      }
    }
  ],
  "metadata": {
    "pact-js": {
      "version": "16.5.0"
    },
    "pactRust": {
      "ffi": "0.5.4",
      "models": "1.3.11"
    },
    "pactSpecification": {
      "version": "3.0.0"
    }
  },
  "provider": {
    "name": "doctors"
  }
}